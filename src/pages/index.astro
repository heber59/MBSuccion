---
import Layout from '../layouts/Layout.astro';
import MainHeader from '../components/MainHeader.astro';
import MainFooter from '../components/MainFooter.astro';
import Hero from '../components/Hero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactButton from '../components/ContactButton.astro';

const pageTitle = 'MB Aire y Succión | Servicio Técnico en Bogotá';
const description =
	'MB Aire y Succión en Bogotá, Fontibón. Servicio técnico, mantenimiento, fabricación y venta de equipos para el sector odontológico e industrial.';
const keywords = [
	'MB Aire y Succión',
	'Bogotá',
	'Fontibón',
	'servicio técnico odontológico',
	'compresores industriales',
	'mantenimiento de compresores',
	'bobinado de motores',
];

const odontologiaServices = [
	{ title: 'Equipos y Suministros', description: 'Venta de compresores, bombas de succión y sillas odontológicas de las mejores marcas.', href: '/odontologia/compresores-dentales/' },
	{ title: 'Servicio Técnico', description: 'Mantenimiento preventivo y correctivo para asegurar la continuidad de su clínica.', href: '/odontologia/mantenimiento-equipos-odontologicos/' },
	{ title: 'Succión a Medida', description: 'Diseñamos e instalamos sistemas de succión especializados según su flujo de trabajo.', href: '/odontologia/bombas-de-succion/' },
];

const industrialServices = [
	{ title: 'Compresores de Pistón', description: 'Reparación y mantenimiento especializado para equipos lubricados de pistón.', href: '/industrial/compresores-piston/' },
	{ title: 'Compresores de Tornillo', description: 'Servicio técnico orientado a la estabilidad y rendimiento de sistemas de tornillo.', href: '/industrial/compresores-tornillo/' },
	{ title: 'Bobinado de Motores', description: 'Recuperación técnica de motores eléctricos con mano de obra especializada.', href: '/industrial/bobinado-de-motores-electricos/' },
];

const faqs = [
	{ question: '¿Dónde está ubicada MB Aire y Succión?', answer: 'Estamos ubicados en Fontibón, Bogotá, Colombia, atendiendo a todo el sector.' },
	{ question: '¿Qué servicios ofrecen para odontología?', answer: 'Suministro de compresores, bombas de succión, mantenimiento de equipos y sistemas a medida.' },
	{ question: '¿Atienden emergencias técnicas industriales?', answer: 'Sí, realizamos diagnósticos precisos y reparaciones para minimizar el tiempo de inactividad.' },
];

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'LocalBusiness',
		name: 'MB Aire y Succión',
		url: 'https://heber59.github.io',
		description,
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Bogotá',
			addressRegion: 'Fontibón',
			addressCountry: 'CO',
		},
	},
];
---

<Layout title={pageTitle} description={description} keywords={keywords} structuredData={structuredData}>
	<MainHeader />
	
	<main>
		<Hero 
			title="Soluciones Técnicas Confiables en Aire y Succión"
			lead="Especialistas en servicio técnico, mantenimiento y fabricación de equipos para el sector odontológico e industrial en Bogotá."
			primaryCTA="Área Odontológica"
			primaryHref="/odontologia/"
			secondaryCTA="Área Industrial"
			secondaryHref="/industrial/"
		/>

		<ServiceGrid 
			id="odontologia"
			eyebrow="Sector Odontológico"
			title="Equipos y Soporte para su Clínica"
			description="Garantizamos el funcionamiento óptimo de su consultorio con tecnología de punta y respaldo técnico especializado."
			services={odontologiaServices}
			theme="dental"
		/>

		<ServiceGrid 
			id="industrial"
			eyebrow="Sector Industrial"
			title="Potencia y Continuidad Operativa"
			description="Mantenimiento integral de compresores y motores para asegurar la productividad de su industria."
			services={industrialServices}
			theme="industrial"
		/>

		<FAQSection faqs={faqs} />
		
		<ContactButton />
	</main>

	<MainFooter />
</Layout>
