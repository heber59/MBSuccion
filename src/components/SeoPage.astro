---
import Layout from '../layouts/Layout.astro';
import type { PageEntry } from '../data/site-pages';

interface Props {
	page: PageEntry;
}

const { page } = Astro.props;

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		name: page.h1,
		url: new URL(page.pathname, Astro.site ?? 'https://example.com').toString(),
		description: page.description,
		inLanguage: 'es',
		keywords: page.keywords.join(', '),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: page.faqs.map((faq) => ({
			'@type': 'Question',
			name: faq.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: faq.answer,
			},
		})),
	},
];
---

<Layout
	title={page.title}
	description={page.description}
	pathname={page.pathname}
	keywords={page.keywords}
	structuredData={structuredData}
>
	<main class="page-shell">
		<section class="hero">
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href="/">Inicio</a>
				<span>/</span>
				<span>{page.title}</span>
			</nav>
			<p class="eyebrow">{page.eyebrow}</p>
			<h1>{page.h1}</h1>
			<p class="intro">{page.intro}</p>
			<div class="cta-row">
				{page.ctaLinks.map((link) => (
					<a class="cta primary" href={link.href}>{link.label}</a>
				))}
			</div>
		</section>

		<section class="section two-col">
			<article class="panel">
				<h2>Aspectos principales</h2>
				<ul class="check-list">
					{page.primaryPoints.map((point) => (
						<li>{point}</li>
					))}
				</ul>
			</article>
			<article class="panel alt">
				<h2>Por que esta pagina importa</h2>
				<ul class="check-list">
					{page.secondaryPoints.map((point) => (
						<li>{point}</li>
					))}
				</ul>
			</article>
		</section>

		<section class="section">
			<div class="section-heading">
				<p class="eyebrow">Rutas relacionadas</p>
				<h2>Conexion con el resto del sitio</h2>
			</div>
			<div class="link-grid">
				{page.relatedLinks.map((link) => (
					<a class="link-card" href={link.href}>
						<h3>{link.label}</h3>
						<p>Ir a esta ruta relacionada para reforzar contexto y navegacion.</p>
					</a>
				))}
			</div>
		</section>

		<section class="section">
			<div class="section-heading">
				<p class="eyebrow">Preguntas frecuentes</p>
				<h2>Informacion util para usuarios y buscadores</h2>
			</div>
			<div class="faq-grid">
				{page.faqs.map((faq) => (
					<article class="faq-item">
						<h3>{faq.question}</h3>
						<p>{faq.answer}</p>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 24px 0 56px;
	}

	.hero,
	.panel,
	.link-card,
	.faq-item {
		background: rgba(255, 255, 255, 0.84);
		border: 1px solid rgba(16, 33, 47, 0.08);
		border-radius: 24px;
		box-shadow: 0 24px 80px rgba(16, 33, 47, 0.1);
	}

	.hero {
		padding: 34px;
	}

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		font-size: 0.95rem;
		color: #51606c;
		margin-bottom: 18px;
	}

	.breadcrumbs a {
		text-decoration: none;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.76rem;
		font-weight: 700;
		color: #156b86;
		margin: 0 0 14px;
	}

	h1,
	h2,
	h3,
	p,
	ul {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(2.3rem, 5vw, 4.2rem);
		line-height: 0.98;
		margin-bottom: 18px;
		max-width: 14ch;
	}

	h2 {
		font-size: clamp(1.6rem, 3vw, 2.4rem);
		line-height: 1.05;
		margin-bottom: 18px;
	}

	h3 {
		font-size: 1.2rem;
		margin-bottom: 12px;
	}

	.intro,
	.check-list li,
	.link-card p,
	.faq-item p {
		color: #51606c;
		font-size: 1.02rem;
		line-height: 1.72;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.cta {
		text-decoration: none;
		padding: 13px 18px;
		border-radius: 999px;
		font-weight: 700;
	}

	.primary {
		background: linear-gradient(135deg, #d96b00, #f19a3e);
		color: #fffaf2;
	}

	.section {
		padding-top: 24px;
	}

	.two-col,
	.link-grid,
	.faq-grid {
		display: grid;
		gap: 20px;
	}

	.two-col,
	.link-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.panel,
	.faq-item {
		padding: 28px;
	}

	.alt {
		background:
			linear-gradient(120deg, rgba(217, 107, 0, 0.08), rgba(21, 107, 134, 0.08)),
			rgba(255, 255, 255, 0.9);
	}

	.check-list {
		padding-left: 18px;
		margin-bottom: 0;
	}

	.check-list li + li {
		margin-top: 12px;
	}

	.section-heading {
		margin-bottom: 18px;
	}

	.link-card {
		text-decoration: none;
		padding: 24px;
	}

	.faq-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	@media (max-width: 860px) {
		.two-col,
		.link-grid,
		.faq-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			padding: 28px 22px;
		}

		h1 {
			max-width: none;
		}
	}
</style>
