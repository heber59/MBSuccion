---
import Layout from '../layouts/Layout.astro';
import MainHeader from '../components/MainHeader.astro';
import MainFooter from '../components/MainFooter.astro';
import type { PageEntry } from '../data/site-pages';

interface Props {
	page: PageEntry;
}

const { page } = Astro.props;

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		name: page.h1,
		url: new URL(page.pathname, Astro.site ?? 'https://example.com').toString(),
		description: page.description,
		inLanguage: 'es',
		keywords: page.keywords.join(', '),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: page.faqs.map((faq) => ({
			'@type': 'Question',
			name: faq.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: faq.answer,
			},
		})),
	},
];
---

<Layout
	title={page.title}
	description={page.description}
	pathname={page.pathname}
	keywords={page.keywords}
	structuredData={structuredData}
>
	<MainHeader />
	
	<main class="page-shell">
		<section class="hero-inner">
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href="/">Inicio</a>
				<span class="sep">/</span>
				<span>{page.title}</span>
			</nav>
			<span class="eyebrow">{page.eyebrow}</span>
			<h1>{page.h1}</h1>
			<p class="intro">{page.intro}</p>
			<div class="cta-row">
				{page.ctaLinks.map((link) => (
					<a class="btn primary" href={link.href}>{link.label}</a>
				))}
			</div>
		</section>

		<div class="container content-grid">
			<section class="panels">
				<article class="panel dental">
					<h2>Aspectos principales</h2>
					<ul class="check-list">
						{page.primaryPoints.map((point) => (
							<li>{point}</li>
						))}
					</ul>
				</article>
				<article class="panel industrial">
					<h2>Por qué importa</h2>
					<ul class="check-list">
						{page.secondaryPoints.map((point) => (
							<li>{point}</li>
						))}
					</ul>
				</article>
			</section>

			<section class="related">
				<h2 class="section-title">Rutas relacionadas</h2>
				<div class="link-grid">
					{page.relatedLinks.map((link) => (
						<a class="link-card" href={link.href}>
							<h3>{link.label}</h3>
							<p>Información técnica y servicios relacionados en esta área.</p>
						</a>
					))}
				</div>
			</section>

			<section class="faqs">
				<h2 class="section-title">Preguntas frecuentes</h2>
				<div class="faq-grid">
					{page.faqs.map((faq) => (
						<article class="faq-item">
							<h3>{faq.question}</h3>
							<p>{faq.answer}</p>
						</article>
					))}
				</div>
			</section>
		</div>
	</main>

	<MainFooter />
</Layout>

<style>
	.page-shell {
		padding-bottom: 6rem;
	}

	.hero-inner {
		padding: 4rem 0;
		background: var(--dental-bg);
		border-bottom: 1px solid var(--line-soft);
		margin-bottom: 4rem;
		text-align: center;
	}

	.hero-inner .container {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.breadcrumbs {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-bottom: 2rem;
	}

	.eyebrow {
		display: inline-block;
		color: var(--dental-accent);
		font-weight: 700;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		max-width: 25ch;
		margin-inline: auto;
	}

	.intro {
		font-size: 1.15rem;
		color: var(--text-muted);
		max-width: 60ch;
		margin-inline: auto;
		margin-bottom: 2.5rem;
	}

	.cta-row {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		padding: 0.75rem 1.5rem;
		border-radius: 99px;
		font-weight: 600;
	}

	.btn.primary {
		background: var(--text-main);
		color: white;
	}

	.content-grid {
		display: flex;
		flex-direction: column;
		gap: 5rem;
	}

	.panels {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.panel {
		padding: 2.5rem;
		border-radius: var(--radius-lg);
		border: 1px solid var(--line-soft);
	}

	.panel.dental { background: var(--dental-bg); border-color: var(--dental-accent); }
	.panel.industrial { background: var(--ind-bg); border-color: var(--ind-accent); }

	.check-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.check-list li {
		padding-left: 1.5rem;
		position: relative;
		margin-bottom: 1rem;
		color: var(--text-muted);
	}

	.check-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: var(--dental-accent);
		font-weight: 800;
	}

	.section-title {
		font-size: 1.75rem;
		font-weight: 800;
		margin-bottom: 2.5rem;
		text-align: center;
	}

	.link-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5rem;
	}

	.link-card {
		padding: 2rem;
		background: white;
		border: 1px solid var(--line-soft);
		border-radius: var(--radius-lg);
		transition: all 0.2s ease;
	}

	.link-card:hover {
		border-color: var(--dental-accent);
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.faq-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.faq-item h3 {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
	}

	.faq-item p {
		font-size: 0.95rem;
		color: var(--text-muted);
	}
</style>
