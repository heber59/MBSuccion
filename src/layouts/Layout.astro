---
interface Props {
	title?: string;
	description?: string;
	pathname?: string;
	keywords?: string[];
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'MBAireYSuccion | Soluciones en aire y succion',
	description = 'MBAireYSuccion en Bogota, Fontibon, Colombia ofrece servicio tecnico, mantenimiento, fabricacion y venta de equipos para el sector odontologico e industrial.',
	pathname = '/',
	keywords = [
		'aire y succion',
		'sector odontologico',
		'sector industrial',
		'MBAireYSuccion',
		'Bogota',
		'Fontibon',
		'Colombia',
		'compresores',
		'bombas de succion',
	],
	structuredData = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://example.com');
const canonicalUrl = new URL(pathname, siteUrl).toString();
const pageTitle = title.includes('MBAireYSuccion') ? title : `${title} | MBAireYSuccion`;
const schemaList = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.join(', ')} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="author" content="MBAireYSuccion" />
		<meta property="og:locale" content="es_CO" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MBAireYSuccion" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<title>{pageTitle}</title>
		{schemaList.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--page-bg:
			radial-gradient(circle at top left, rgba(255, 195, 113, 0.28), transparent 32%),
			radial-gradient(circle at right 18%, rgba(17, 138, 178, 0.18), transparent 28%),
			linear-gradient(180deg, #fffaf4 0%, #f5f8fb 52%, #eef3f7 100%);
		--surface: rgba(255, 255, 255, 0.86);
		--surface-strong: #ffffff;
		--text: #10212f;
		--muted: #51606c;
		--line: rgba(16, 33, 47, 0.1);
		--accent: #d96b00;
		--accent-deep: #8f3d00;
		--accent-alt: #156b86;
		--shadow: 0 24px 80px rgba(16, 33, 47, 0.12);
		--radius: 24px;
		font-family: "Space Grotesk", "Segoe UI", sans-serif;
	}

	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		background: var(--page-bg);
		color: var(--text);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	img {
		max-width: 100%;
		display: block;
	}
</style>
