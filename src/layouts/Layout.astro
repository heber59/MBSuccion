---
interface Props {
	title?: string;
	description?: string;
	pathname?: string;
	keywords?: string[];
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'MBAireYSuccion | Soluciones en aire y succion',
	description = 'MBAireYSuccion en Bogota, Fontibon, Colombia ofrece servicio tecnico, mantenimiento, fabricacion y venta de equipos para el sector odontologico e industrial.',
	pathname = '/',
	keywords = [
		'aire y succion',
		'sector odontologico',
		'sector industrial',
		'MBAireYSuccion',
		'Bogota',
		'Fontibon',
		'Colombia',
		'compresores',
		'bombas de succion',
	],
	structuredData = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://example.com');
const canonicalUrl = new URL(pathname, siteUrl).toString();
const pageTitle = title.includes('MBAireYSuccion') ? title : `${title} | MBAireYSuccion`;
const schemaList = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.join(', ')} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="author" content="MBAireYSuccion" />
		<meta property="og:locale" content="es_CO" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MBAireYSuccion" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<title>{pageTitle}</title>
		{schemaList.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		/* Base Palette */
		--bg-primary: #ffffff;
		--bg-secondary: #f1f5f9; /* Light gray */
		--text-main: #172a3a;
		--text-muted: #508991;
		--line-soft: rgba(23, 42, 58, 0.1);
		
		/* Themes & Accents (Preserved from requested palette) */
		--brand-light: #d6f3f4;
		--accent-light: #74b3ce;
		--accent-dark: #004346;
		--dental-accent: #508991;
		--dental-bg: #f8fafc;
		
		--ind-accent: #004346;
		--ind-bg: #f1f5f9;

		--radius-lg: 16px;
		--shadow-sm: 0 1px 3px rgba(23, 42, 58, 0.1);
		--shadow-md: 0 10px 30px -10px rgba(23, 42, 58, 0.15);
		
		font-family: "Inter", "Segoe UI", system-ui, sans-serif;
	}

	html {
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
	}

	body {
		background: var(--bg-primary);
		color: var(--text-main);
		line-height: 1.6;
		margin: 0;
		animation: fadeIn 0.4s ease-out;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(4px); }
		to { opacity: 1; transform: translateY(0); }
	}

	*, *::before, *::after { box-sizing: border-box; }
	a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
	img { max-width: 100%; height: auto; display: block; border-radius: 8px; }

	.container {
		width: min(1200px, 100% - 4rem);
		margin-inline: auto;
	}

	@media (max-width: 640px) {
		.container {
			width: min(1200px, 100% - 2rem);
		}
	}
</style>
